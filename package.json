{
  "name": "toy-api-server-nodejs",
  "version": "1.0.0",
  "description": "A toy API server built with Node.js and Fastify.",
  "main": "nodemon bin/www",
  "scripts": {
    "dev": "DEBUG=toy-api-demo* nodemon bin/www",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node bin/www",
    "test": "node --test"
  },
  "keywords": [
    "nodejs",
    "fastify",
    "api-server",
    "toy-project"
  ],
  "author": "Đăng Khoa <i.am@dangkhoa.dev>",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "debug": "^4.4.3",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "lodash-core": "^4.17.19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.2"
  }
}
